
<!doctype html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<title>Budget Manager</title>
	<link rel="stylesheet" href="/webstyle.css">
</head>

<body>
	<header>
		<h1>Budget Manager</h1>
		<nav>
			<button onclick="changeBudget()">Change Budget</button>
			<a href="/addTransaction">
				<button>Add Transaction</button>
			</a>
			<a href="/deleteTransactions">
				<button>Delete Transactions</button>
			</a>
			<a href="/clear">
				<button>Clear All Transactions</button>
			</a>
			<a href="/logout"><button>Logout</button></a>
        </nav>
	</header>

	<div>
		<p id="total-budget"> </p>
	</div>
	<hr>
	<div>
		<p>
			All Transactions:<br>
			<%- transactionInfo -%>
		</p>
	</div>
	<hr>
	<div>
		<p id="budget-left"> Remaining Budget: </p>
	</div>

	<!-- giving myself credit -->
    <footer>
        <p>Made by Samuel Rowe</p>
    </footer>

	
	
</body>
<script>
let totalSpent = Number("<%= totalSpent %>") || 0;
let userBudget = Number("<%= userBudget %>") || 1000; // From MongoDB now!

document.getElementById("total-budget").innerText = `Total Budget: $${userBudget.toLocaleString()}`;
const remaining = userBudget - totalSpent;
document.getElementById("budget-left").innerText = `Remaining Budget: $${remaining.toLocaleString()}`;

if (remaining < 0) {
  document.getElementById("budget-left").innerText += "\nYou are over budget. Fix it!";
}

async function changeBudget() {
  let newBudget = prompt("What is your new budget in dollars?");
  let num = Number(newBudget);
  
  if (Number.isFinite(num) && num > 0) {
    // Save to MongoDB via API
    const response = await fetch('/updateBudget', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${getCookie('token')}`
      },
      body: JSON.stringify({ budget: num })
    });
    
    if (response.ok) {
      alert(`Budget changed to $${num.toLocaleString()}`);
      location.reload(); // Refresh to show updated budget
    } else {
      alert('Failed to update budget');
    }
  } else {
    alert("Not a valid number");
  }
}

function getCookie(name) {
  const value = `; ${document.cookie}`;
  const parts = value.split(`; ${name}=`);
  if (parts.length === 2) return parts.pop().split(';').shift();
}
</script>

</html>
